  "thinking": {
    "enabled": false
  },
  "system_prompt": {
    "system_prompt_mode": "system_instruction"
  },
  "notes": "Placeholder snapshot 2026-04-07 capturing call_fireworks() arg defaults: max_tokens=60, temperature=0.7, FIREWORKS_TIMEOUT default 15s, model_string=FIREWORKS_MODEL default. CB threshold/cooldown stay per-provider env vars per DECISIONS.md #6."
}
