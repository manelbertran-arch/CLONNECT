# CLONNECT Backend - Environment Variables Example
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# =============================================================================
# LLM Configuration
# =============================================================================
# Primary: Gemini Flash-Lite (low cost, fast)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback: GPT-4o-mini (automatic when Gemini fails)
OPENAI_API_KEY=your_openai_api_key_here

# Embeddings: OpenAI text-embedding-3-small (1536d)
# Uses the same OPENAI_API_KEY above

# Admin authentication
CLONNECT_ADMIN_KEY=your-secure-admin-key

# =============================================================================
# DATABASE (optional - uses JSON fallback if not set)
# =============================================================================

# DATABASE_URL=postgresql://user:password@host:5432/clonnect
# ENABLE_JSON_FALLBACK=false

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret - REQUIRED for production (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# CORS Origins - comma-separated list of allowed origins
# Leave empty for development (allows all), set for production
# CORS_ORIGINS=https://app.clonnect.com,https://dashboard.clonnect.com

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

DATA_PATH=./data
LOG_LEVEL=INFO
DEBUG=false
DEFAULT_CREATOR_ID=manel

# URLs
FRONTEND_URL=https://www.clonnectapp.com
API_URL=https://www.clonnectapp.com

# =============================================================================
# INSTAGRAM INTEGRATION
# =============================================================================

# INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
# INSTAGRAM_PAGE_ID=your_facebook_page_id
# INSTAGRAM_USER_ID=your_instagram_user_id
# INSTAGRAM_APP_SECRET=your_meta_app_secret
INSTAGRAM_VERIFY_TOKEN=clonnect_verify_2024

# =============================================================================
# WHATSAPP INTEGRATION
# =============================================================================

# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
# WHATSAPP_CONFIG_ID=your_whatsapp_config_id
# WHATSAPP_REDIRECT_URI=https://your-api.com/oauth/whatsapp/callback
WHATSAPP_VERIFY_TOKEN=clonnect_whatsapp_verify_2024
# WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# =============================================================================
# TELEGRAM BOT
# =============================================================================

# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_WEBHOOK_URL=https://your-api-url.com/webhook/telegram
# TELEGRAM_PROXY_URL=https://your-cloudflare-worker.workers.dev
# TELEGRAM_PROXY_SECRET=your_proxy_secret

# =============================================================================
# PAYMENT INTEGRATIONS
# =============================================================================

# Stripe
# STRIPE_SECRET_KEY=sk_live_or_test_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_REDIRECT_URI=https://your-api.com/oauth/paypal/callback
# PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_MODE=sandbox

# Hotmart
# HOTMART_WEBHOOK_TOKEN=your_hotmart_token

# =============================================================================
# CALENDAR INTEGRATIONS
# =============================================================================

# Calendly
# CALENDLY_API_KEY=your_calendly_api_key
# CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_secret

# Cal.com
# CALCOM_API_KEY=your_calcom_api_key
# CALCOM_WEBHOOK_SECRET=your_calcom_webhook_secret
# CALCOM_BASE_URL=https://api.cal.com/v1

# =============================================================================
# META OAUTH (for Instagram/WhatsApp embedded signup)
# =============================================================================

# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
# META_REDIRECT_URI=https://your-api.com/oauth/meta/callback

# =============================================================================
# GOOGLE OAUTH (for Google Meet/Calendar)
# =============================================================================

# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://your-api.com/oauth/google/callback

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# ALERTS & NOTIFICATIONS
# =============================================================================

TELEGRAM_ALERTS_ENABLED=false
# TELEGRAM_ALERTS_BOT_TOKEN=your_alerts_bot_token
# TELEGRAM_ALERTS_CHAT_ID=your_chat_id

# Email (Resend)
# RESEND_API_KEY=your_resend_api_key
# CREATOR_EMAIL=creator@example.com
SMTP_ENABLED=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================

REQUIRE_GDPR_CONSENT=false
TRANSPARENCY_ENABLED=false
AUTO_DM_ON_COMMENTS=false
ENABLE_GUARDRAILS=true
ENABLE_DEMO_RESET=true

# RAG Enhancement (default: true)
# Cross-encoder reranking for better precision (+100-200ms latency)
ENABLE_RERANKING=true
# BM25 hybrid search for keyword matching (+50ms latency)
ENABLE_BM25_HYBRID=true

# Cognitive Engine - Full Integration
ENABLE_EDGE_CASE_DETECTION=true
ENABLE_CITATIONS=true
ENABLE_MESSAGE_SPLITTING=true
ENABLE_QUESTION_REMOVAL=true
ENABLE_VOCABULARY_EXTRACTION=true
ENABLE_SELF_CONSISTENCY=false
ENABLE_SEMANTIC_MEMORY_PGVECTOR=true

# Nurturing Sequences - P0 FIX
# Set to true for testing (no messages sent), false for production (messages WILL send)
NURTURING_DRY_RUN=false
# Scheduler interval in seconds (default: 300 = 5 minutes)
NURTURING_SCHEDULER_INTERVAL=300

# Rate Limiting - disable for testing
RATE_LIMIT_ENABLED=true

# Escalation webhook (Slack, Discord, etc.)
# ESCALATION_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# =============================================================================
# LLM PROVIDER ROUTING
# =============================================================================
# Which provider to try first: "gemini" (default), "together", "deepinfra"
# LLM_PRIMARY_PROVIDER=gemini

# Together AI (Qwen3-32B or fine-tuned models)
# TOGETHER_API_KEY=
# TOGETHER_MODEL=Qwen/Qwen3-32B

# DeepInfra (Qwen3-32B or fine-tuned models)
# DEEPINFRA_API_KEY=
# DEEPINFRA_MODEL=Qwen/Qwen3-32B

# =============================================================================
# MAGIC SLICE (Phase 2 - Media Connectors)
# =============================================================================

# For audio transcription (Whisper API)
# OPENAI_API_KEY=sk-your_openai_key (same as above if using OpenAI for LLM)

# For YouTube data API (optional, yt-dlp works without it)
# YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
ENVIRONMENT=production

# =============================================================================
# EMAIL NOTIFICATIONS (SMTP)
# =============================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# NOTIFICATION_EMAIL=alerts@yourdomain.com

# =============================================================================
# BACKUP & STORAGE
# =============================================================================

# AWS S3 (for backups)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# S3_BUCKET=clonnect-backups
# AWS_REGION=eu-west-1

# =============================================================================
# PLATFORM AUTO-DETECTED (set by Railway/Render/Vercel - DO NOT SET MANUALLY)
# =============================================================================

# These are automatically set by deployment platforms:
# RAILWAY_PUBLIC_URL - Your Railway public URL
# RAILWAY_GIT_COMMIT_SHA - Current git commit
# RENDER_EXTERNAL_URL - Your Render URL
# PORT - Server port (default: 8000)

# =============================================================================
# TESTING (for pytest)
# =============================================================================

# Set to true when running tests
# TESTING=true
