[run]
source = api,core,services
omit =
    */tests/*
    */_archive/*
    */migrations/*
    */__pycache__/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.
    raise NotImplementedError
    pass
show_missing = true
precision = 1

[html]
directory = htmlcov
