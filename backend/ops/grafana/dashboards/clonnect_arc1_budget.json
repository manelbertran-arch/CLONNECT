{
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "heatmap", "name": "Heatmap", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "ARC1 BudgetOrchestrator — token budget utilization, truncations, and assembly performance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 5}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(budget_orchestrator_duration_ms_bucket{creator_id=~\"$creator_id\"}[5m])) by (le, creator_id))",
          "legendFormat": "P50 {{creator_id}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(budget_orchestrator_duration_ms_bucket{creator_id=~\"$creator_id\"}[5m])) by (le, creator_id))",
          "legendFormat": "P95 {{creator_id}}",
          "refId": "B"
        }
      ],
      "title": "Budget orchestrator assembly duration P50/P95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "percentunit", "min": 0, "max": 1.2},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(dm_budget_utilization_bucket{creator_id=~\"$creator_id\"}[10m])) by (le, creator_id))",
          "legendFormat": "P50 {{creator_id}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(dm_budget_utilization_bucket{creator_id=~\"$creator_id\"}[10m])) by (le, creator_id))",
          "legendFormat": "P95 {{creator_id}}",
          "refId": "B"
        }
      ],
      "title": "Token budget utilization P50/P95 (fraction 0–1)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(budget_section_truncation_total[5m])) by (section_name)",
          "legendFormat": "{{section_name}}",
          "refId": "A"
        }
      ],
      "title": "Sections truncated by budget (rate per section)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 4,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dm_budget_sections_dropped_total{creator_id=~\"$creator_id\"}[10m])) by (section_name)",
          "legendFormat": "Dropped: {{section_name}}",
          "refId": "A"
        }
      ],
      "title": "Sections dropped by name (rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dm_budget_sections_compressed_total{creator_id=~\"$creator_id\"}[10m])) by (section_name)",
          "legendFormat": "Compressed: {{section_name}}",
          "refId": "A"
        }
      ],
      "title": "Sections compressed by name (rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 20}]}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "dm_budget_sections_selected{creator_id=~\"$creator_id\"}",
          "legendFormat": "{{creator_id}}",
          "refId": "A"
        }
      ],
      "title": "Sections selected (current)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["clonnect", "arc1", "budget"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(dm_budget_utilization_count, creator_id)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "creator_id",
        "query": {"query": "label_values(dm_budget_utilization_count, creator_id)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Creator"
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Clonnect — ARC1 Budget Orchestrator",
  "uid": "clonnect-arc1-budget",
  "version": 0,
  "weekStart": ""
}
