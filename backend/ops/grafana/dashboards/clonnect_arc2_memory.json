{
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "ARC2 Lead Memory — writes by type, read latency, dual-write divergence",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(memory_extraction_total{creator_id=~\"$creator_id\"}[5m])) by (memory_type)",
          "legendFormat": "{{memory_type}}",
          "refId": "A"
        }
      ],
      "title": "Memory facts extracted by type (rate/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(lead_memories_read_total{creator_id=~\"$creator_id\"}[5m])) by (source)",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Lead memory reads by source (rate/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 5}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(lead_memories_read_duration_ms_bucket{creator_id=~\"$creator_id\"}[5m])) by (le, creator_id))",
          "legendFormat": "P50 {{creator_id}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(lead_memories_read_duration_ms_bucket{creator_id=~\"$creator_id\"}[5m])) by (le, creator_id))",
          "legendFormat": "P95 {{creator_id}}",
          "refId": "B"
        }
      ],
      "title": "Memory read latency P50/P95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dual_write_success_total[5m])) by (source)",
          "legendFormat": "Success {{source}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dual_write_failure_total[5m])) by (source, error_type)",
          "legendFormat": "FAIL {{source}}/{{error_type}}",
          "refId": "B"
        }
      ],
      "title": "Dual-write success vs failure (rate/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "percentunit", "min": 0, "max": 1},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dual_write_failure_total[5m])) / (sum(rate(dual_write_success_total[5m])) + sum(rate(dual_write_failure_total[5m])))",
          "legendFormat": "Dual-write failure rate",
          "refId": "A"
        }
      ],
      "title": "Dual-write failure rate (fraction)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(memory_extraction_total{creator_id=~\"$creator_id\"}[10m])) by (creator_id, memory_type)",
          "legendFormat": "{{creator_id}} / {{memory_type}}",
          "refId": "A"
        }
      ],
      "title": "Memory extraction breakdown by creator × type",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["clonnect", "arc2", "memory"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(memory_extraction_total, creator_id)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "creator_id",
        "query": {"query": "label_values(memory_extraction_total, creator_id)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Creator"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Clonnect — ARC2 Lead Memory",
  "uid": "clonnect-arc2-memory",
  "version": 0,
  "weekStart": ""
}
